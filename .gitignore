# Whitelist repo: ignore everything unless explicitly allowed below.
*

# Repo metadata/docs
!.gitignore
!README.md
!LICENSE

# Admin automation and root launch helpers
!admin/
!admin/**
!*.cmd
!*.bat
!*.ps1

# Public-safe DayZ server config examples only. Keep real serverDZ*.cfg private:
# they may contain admin passwords, ports, shard IDs, or local-only values.
serverDZ*.cfg
!serverDZ*.example.cfg
ban.txt
whitelist.txt
Server*.DayZProfile
Server*.xml
dayz*.xml
dayz*.gproj

# Mission/config work that is safe to share.
!mpmissions/
mpmissions/*

# Active public-safe mission subsets. Full mission folders stay private because
# storage, map files, base CE, and local persistence can be large or sensitive.
