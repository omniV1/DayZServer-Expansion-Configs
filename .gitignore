!mpmissions/dayzOffline.chernarusplus/expansion/traders/**
!mpmissions/dayzOffline.chernarusplus/expansion/traderzones/
!mpmissions/dayzOffline.chernarusplus/expansion/traderzones/**

# Expansion profile configs. Keep player/account persistence private.
!profiles/
profiles/*
!profiles/ExpansionMod/
profiles/ExpansionMod/*
!profiles/ExpansionMod/Loadouts/
!profiles/ExpansionMod/Loadouts/**
!profiles/ExpansionMod/Market/
!profiles/ExpansionMod/Market/**
!profiles/ExpansionMod/Quests/
!profiles/ExpansionMod/Quests/**
!profiles/ExpansionMod/Settings/
!profiles/ExpansionMod/Settings/**
!profiles/ExpansionMod/Traders/
!profiles/ExpansionMod/Traders/**
profiles/ExpansionMod/**/PlayerData/
profiles/ExpansionMod/**/PlayerData/**
profiles/ExpansionMod/**/GroupData/
profiles/ExpansionMod/**/GroupData/**
