# Whitelist repo: ignore everything unless explicitly allowed below.
*

# Repo metadata/docs
!.gitignore
!README.md
!QUICKSTART.md
!REPO_MAP.md
!MODS.md
!BALANCE.md
!CONTRIBUTING.md
!CONTROL_CENTER_ROADMAP.md
!LICENSE
!.github/
!.github/**

# winget package manifests (submitted to microsoft/winget-pkgs)
!winget/
!winget/**

# Admin automation and root launch helpers
!admin/
!admin/**
admin/backups/
admin/backups/**
local_runtime/
local_runtime/**
!*.cmd
!*.bat
!*.ps1

# Public-safe DayZ server config examples only. Keep real serverDZ*.cfg private:
# they may contain admin passwords, ports, shard IDs, or local-only values.
serverDZ*.cfg
!serverDZ*.example.cfg
ban.txt
whitelist.txt
Server*.DayZProfile
Server*.xml
dayz*.xml
dayz*.gproj

# Mission/config work that is safe to share.
!mpmissions/
mpmissions/*

